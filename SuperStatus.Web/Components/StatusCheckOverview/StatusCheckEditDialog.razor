@using Humanizer
@using Microsoft.AspNetCore.Components.Authorization
@using SuperStatus.Data.Constants

@inject StatusApiClient StatusApi
@inject IDialogService DialogService

<MudDialog Class="hud-dialog">
    <TitleContent>
        <div class="hud-dialog-head">
            <span class="tag accent"><span class="led up"></span>@(StatusCheck.Id > 0 ? "EDIT CHECK" : "ADD CHECK")</span>
            <span class="hud-dialog-name">@(string.IsNullOrWhiteSpace(StatusCheck.Title) ? "New status check" : StatusCheck.Title)</span>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="_form">

            <MudGrid>
                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="StatusCheck.Title"
                                  Label="Title"
                                  For="@(()=>StatusCheck.Title)"
                                  Required="true"
                                  RequiredError="Title is required." />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="StatusCheck.Description"
                                  Label="Description"
                                  For="@(()=>StatusCheck.Description)"
                                  Lines="3"
                                  Placeholder="Optional description"
                                  Text="@StatusCheck.Description" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="StatusCheck.StatusCheckUrl"
                                  Label="Status Check URL"
                                  For="@(()=>StatusCheck.StatusCheckUrl)"
                                  Required="true"
                                  RequiredError="Status URL is required."
                                  InputType="InputType.Url"
                                  Placeholder="https://service/health" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="StatusCheck.ServiceLogoUrl"
                                  Label="Service Logo URL"
                                  For="@(()=>StatusCheck.ServiceLogoUrl)"
                                  InputType="InputType.Url"
                                  Placeholder="https://cdn.example.com/logo.png" />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Checked="StatusCheck.Enabled" Color="Color.Primary" Label="Enabled"></MudCheckBox>
                </MudItem>

            </MudGrid>


            <MudGrid>
                <MudItem xs="12">
                    <div class="hud-dialog-section">Success Response</div>
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="int"
                               @bind-Value="StatusCheck.ExpectedStatusCode"
                               Label="Expected Status Code"
                               For="@(()=>StatusCheck.ExpectedStatusCode)"
                               Required="true"
                               RequiredError="Expected HTTP status code is required."
                               Dense="true">
                        @foreach (var statusCode in CommonSuccessStatusCodes)
                        {
                            <MudSelectItem T="int" Value="statusCode.Code"><span>@statusCode.Code - @statusCode.Description</span></MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudNumericField T="long"
                                     @bind-Value="StatusCheck.ExpectedResponseTimeInMs"
                                     Label="Expected Response Time (ms)"
                                     For="@(()=>StatusCheck.ExpectedResponseTimeInMs)"
                                     Min="0"
                                     Adornment="Adornment.End"
                                     AdornmentIcon="@Icons.Material.Filled.Speed"
                                     HelperText="Max acceptable response time." />
                </MudItem>
                <MudItem xs="12">
                    @* Issue #82: per-check polling cadence. Server clamps to
                       5–3600 s on save; this Min/Max is the advisory client guard. *@
                    <MudNumericField T="int"
                                     @bind-Value="StatusCheck.IntervalSeconds"
                                     Label="Polling Interval (s)"
                                     For="@(()=>StatusCheck.IntervalSeconds)"
                                     Min="5"
                                     Max="3600"
                                     Adornment="Adornment.End"
                                     AdornmentIcon="@Icons.Material.Filled.Timer"
                                     HelperText="How often this check runs (5–3600 s)." />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Checked="StatusCheck.IsWebHookOnErrorEnabled" Color="Color.Primary" Label="Webhook On Error"
                                 Immediate="true"
                                 OnChanged="OnWebhookToggle"></MudCheckBox>
                </MudItem>
            </MudGrid>
            <MudGrid>
                <MudItem xs="12">
                    <div class="hud-dialog-section">Webhook</div>
                </MudItem>
                <MudItem xs="12" sm="8">
                    <MudTextField T="string"
                                  @bind-Value="StatusCheck.WebHookOnErrorUrl"
                                  Label="Webhook URL"
                                  For="@(()=>StatusCheck.WebHookOnErrorUrl)"
                                  InputType="InputType.Url"
                                  Required="true"
                                  RequiredError="Webhook URL required when enabled."
                                  Placeholder="https://hooks.example.com/error" />
                </MudItem>

                <MudItem xs="12" sm="4">
                    <MudNumericField T="int"
                                     @bind-Value="StatusCheck.ThrottleWebHookToExecuteOnlyEveryXMinutes"
                                     Label="Webhook Throttle (min)"
                                     For="@(()=>StatusCheck.ThrottleWebHookToExecuteOnlyEveryXMinutes)"
                                     Min="0"
                                     HelperText="0 = trigger every failure." />
                </MudItem>


            </MudGrid>

            @* Issue #168: per-check opt-in for AI-authored incidents on sustained
               downtime. Only fires when the instance's AI settings are enabled
               (/admin → AI / Automation); otherwise this toggle is inert. *@
            <MudGrid>
                <MudItem xs="12">
                    <div class="hud-dialog-section">Automation</div>
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Checked="StatusCheck.AutoIncidentEnabled" Color="Color.Primary"
                                 Label="Auto-draft an incident if this service stays down"></MudCheckBox>
                </MudItem>
            </MudGrid>

            @* Issue #241/#253: per-check alert rules. The decision engine + audit
               log are live now; email delivery lands in Phase B, web-push in Phase C.
               All fields default off → no change for existing checks. *@
            <MudGrid>
                <MudItem xs="12">
                    <div class="hud-dialog-section">Alerts</div>
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Checked="StatusCheck.EmailAlertsEnabled" Color="Color.Primary"
                                 Label="Email alerts"></MudCheckBox>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="StatusCheck.EmailRecipients"
                                  Label="Email recipients"
                                  Placeholder="ops@example.com, oncall@example.com"
                                  HelperText="Comma/space-separated. Used when email alerts are on (delivery: Phase B)." />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Checked="StatusCheck.WebPushAlertsEnabled" Color="Color.Primary"
                                 Label="Web-push alerts (delivery: Phase C)"></MudCheckBox>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int"
                                     @bind-Value="StatusCheck.AlertOnFailureThreshold"
                                     Label="Alert after N failures"
                                     Min="0"
                                     HelperText="0 = off." />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int"
                                     @bind-Value="StatusCheck.AlertOnOutageMinutes"
                                     Label="Or down ≥ (min)"
                                     Min="0"
                                     HelperText="0 = off." />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int"
                                     @bind-Value="StatusCheck.AlertThrottleMinutes"
                                     Label="Throttle (min)"
                                     Min="0"
                                     HelperText="Min minutes between alerts." />
                </MudItem>
                <MudItem xs="12">
                    <MudCheckBox T="bool" @bind-Checked="StatusCheck.AlertOnRecovery" Color="Color.Primary"
                                 Label="Also alert on recovery"></MudCheckBox>
                </MudItem>
            </MudGrid>

        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Outlined" Color="Color.Secondary">Cancel</MudButton>
        <MudButton OnClick="SubmitAsync" Disabled="@_submitting" Color="Color.Primary" Variant="Variant.Filled">
            @(!_submitting ? "Save" : "Saving...")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public required StatusCheckViewModelBase StatusCheck { get; set; }

    private MudForm? _form;
    private bool _submitting;

    // Common 2xx success status codes
    private readonly (int Code, string Description)[] CommonSuccessStatusCodes =
    [
        (200, "OK"),
        (201, "Created"),
        (202, "Accepted"),
        (204, "No Content"),
        (206, "Partial Content")
    ];

    private async Task SubmitAsync()
    {
        if (_form is null) return;
        await _form.Validate();
        if (!_form.IsValid) return;

        _submitting = true;
        try
        {

            await StatusApi.UpdateOrAddStatusCheck(StatusCheck);
            MudDialog.Close(DialogResult.Ok(StatusCheck));
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private async void OnWebhookToggle(bool _)
    {
        // Revalidate dependent fields when webhook enabled/disabled
        if (_form is not null)
            await _form.Validate();
        StateHasChanged();
    }
}