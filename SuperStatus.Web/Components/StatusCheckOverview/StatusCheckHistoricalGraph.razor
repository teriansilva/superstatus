@using Microsoft.FluentUI.AspNetCore.Components.DesignTokens
@using SuperStatus.Data.Entities
@inject StatusApiClient StatusApi


    @if (historicalStatusCheckData is { Count: > 0 })
    {
        foreach (var historicalStatusDataDay in historicalStatusCheckData)
        {
            <MudTooltip Arrow="true" Placement="Placement.Top">
                <ChildContent>
                    <MudChip T="string" Class="calculate-box-size" Label="true" Color="@GetBarColor(historicalStatusDataDay)"></MudChip>
                </ChildContent>
                <TooltipContent>
                    @(historicalStatusDataDay.Date) had
                    @(historicalStatusDataDay.FailedResponseCount) times failed,
                    @(historicalStatusDataDay.SlowResponseCount) times slow and
                    @(historicalStatusDataDay.UnreachableCount) times unreachable
                </TooltipContent>
            </MudTooltip>
        }
    }


<style>
    .mud-chip {
        
        height: 32px;
        padding: 4px;
    }

    .mud-tooltip-root
    {
        width: calc(100% / @(historicalStatusCheckData.Count));
    }

</style>


@code
{
    public int BoxWidth = 10;

    [Parameter, EditorRequired]
    public required StatusCheckViewModel statusCheck { get; set; }

    private List<HistoricalStatusDataOverviewChartViewModel> historicalStatusCheckData { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        historicalStatusCheckData = await StatusApi.GetHistoricalStatusData(statusCheck.Id);
    }

    private Color GetBarColor(HistoricalStatusDataOverviewChartViewModel historicalStatusDataDay)
        => historicalStatusDataDay.FailedStatus
            ? Color.Error
            : historicalStatusDataDay.SlowResponse
                ? Color.Warning
                : Color.Success;
}