# SuperStatus — self-host / local-trial environment.
#
#   cp .env.example .env
#
# For a plain localhost trial you can run `docker compose up` WITHOUT creating a
# .env at all — every value below has a working built-in default in
# docker-compose.yml. Copy this file only when you want to change something.
#
# ──────────────────────────────────────────────────────────────────────────────
#  ⚠  SECURITY: the defaults are loopback-only demo values.
#     • Past localhost (a LAN you control), you MUST regenerate the two secrets
#       below — start.sh does this for you. Plain HTTP is OK on a trusted LAN.
#     • On an untrusted network or the public internet, ALSO put it behind a TLS
#       reverse proxy (see docs/self-hosting.md).
#       POSTGRES_PASSWORD       — openssl rand -base64 24
#       OIDC_WEB_CLIENT_SECRET  — openssl rand -base64 24
# ──────────────────────────────────────────────────────────────────────────────

# ── Image version ─────────────────────────────────────────────────────────────
# Which prebuilt image tag to pull from ghcr.io/teriansilva/superstatus-*.
# `latest` tracks the newest release; pin a specific tag (e.g. v1.2.0) for a
# reproducible deploy. To build from source instead of pulling, layer
# docker-compose.build.yml (see docs/self-hosting.md §6).
SUPERSTATUS_VERSION=latest

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=superstatus
POSTGRES_PASSWORD=superstatus_local_dev

# ── URLs ──────────────────────────────────────────────────────────────────────
# WEBAPP_HTTP     — where the browser reaches the web app.
# IDP_PUBLIC_HTTP — the OIDC authority the BROWSER is sent to. id.localhost
#                   resolves to 127.0.0.1 in modern browsers → Identity's
#                   published port. Keep its :PORT in sync with IDENTITY_PORT.
#                   For ANY non-localhost deployment set this to your public
#                   Identity URL (e.g. https://id.example.com, equal to IDP_HTTP);
#                   leaving it at the localhost value behind a TLS proxy keeps the
#                   localhost issuer and the services refuse to start. See
#                   docs/self-hosting.md.
# IDP_HTTP        — the OIDC authority the web/api CONTAINERS use over the compose
#                   network (back-channel discovery / token / JWKS). They rewrite
#                   their own calls from the public host to this internal one.
WEBAPP_HTTP=http://localhost:8080
IDP_PUBLIC_HTTP=http://id.localhost:8081
IDP_HTTP=http://identity:8080

# If your browser does not auto-resolve *.localhost (e.g. older Safari), add this
# line to your hosts file (/etc/hosts, or C:\Windows\System32\drivers\etc\hosts):
#   127.0.0.1   id.localhost

# ── OIDC shared secret ────────────────────────────────────────────────────────
# Shared between Identity (registers the OpenIddict client with this value) and
# Web (presents it on the code + client-credentials flows). Both must match.
OIDC_WEB_CLIENT_SECRET=superstatus_local_dev_oidc

# ── Host binding & ports ──────────────────────────────────────────────────────
# BIND_ADDR — host interface the ports publish on. Defaults to loopback, so a
#   fresh `docker compose up` isn't reachable off the machine. To serve a LAN you
#   control, set 0.0.0.0 (or a specific interface) and regenerate the secrets
#   above — start.sh does both. On an untrusted network or the internet, only
#   expose it through a TLS reverse proxy. See docs/self-hosting.md.
BIND_ADDR=127.0.0.1
WEB_PORT=8080
IDENTITY_PORT=8081

# ── First-run sample data ─────────────────────────────────────────────────────
# Seeds a sample status check so the dashboard is populated on first boot.
# No-op once any check exists. Set to false to start with an empty dashboard.
SEED_SAMPLE_DATA=true

# The first visit creates the administrator account via a setup wizard — there is
# no seeded default login. See README "First run".
