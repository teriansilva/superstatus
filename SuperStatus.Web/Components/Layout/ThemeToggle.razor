@*
    ThemeToggle — issue #177.

    Topbar control that cycles the viewer theme system → light → dark via
    wwwroot/js/hud-theme.js (persisted in localStorage; the HUD palette flips on
    the data-theme attribute, MudBlazor follows through ThemeProvider). The icon
    reflects the active mode. Visible to everyone — it's a per-viewer preference,
    not an operator setting.
*@
@inject IJSRuntime JS

<button class="hud-icon-btn" type="button" @onclick="Cycle"
        title="@Title" aria-label="@Title">
    @switch (_mode)
    {
        case "light":
            @* sun *@
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path fill="currentColor" d="M12 7a5 5 0 1 0 0 10a5 5 0 0 0 0-10m0-5l2.39 3.42C13.65 5.15 12.84 5 12 5s-1.65.15-2.39.42L12 2M3.34 7l4.16-.35C6.45 7.2 5.5 7.97 4.96 8.97L3.34 7m0 10l1.62-1.97c.54 1 1.49 1.77 2.54 2.32L3.34 17M12 22l-2.39-3.42c.74.27 1.55.42 2.39.42s1.65-.15 2.39-.42L12 22m8.66-5l-4.16.35c1.05-.55 2-1.32 2.54-2.32L20.66 17m0-10l-1.62 1.97c-.54-1-1.49-1.77-2.54-2.32L20.66 7Z"/>
            </svg>
            break;
        case "dark":
            @* moon *@
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path fill="currentColor" d="M17.75 4.09l-2.53 1.94l.91 3.06l-2.63-1.81l-2.63 1.81l.91-3.06l-2.53-1.94L12.44 4l1.06-3.09L14.56 4l3.19.09m3.5 6.91l-1.64 1.25l.59 1.98l-1.7-1.17l-1.7 1.17l.59-1.98L15.25 11l2.06-.05L18 9l.69 1.95l2.06.05m-2.28 4.95c.83-.08 1.72 1.1 1.19 1.85c-.32.45-.66.87-1.08 1.27C15.17 23 8.84 23 4.94 19.07c-3.91-3.9-3.91-10.24 0-14.14c.4-.4.82-.74 1.27-1.07c.75-.53 1.93.36 1.85 1.19c-.27 2.86.69 5.83 2.89 8.02a9.96 9.96 0 0 0 8.02 2.89Z"/>
            </svg>
            break;
        default:
            @* auto / system *@
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path fill="currentColor" d="M12 2a10 10 0 0 0 0 20a10 10 0 0 0 0-20m0 2v16a8 8 0 0 1 0-16Z"/>
            </svg>
            break;
    }
</button>

@code {
    private string _mode = "system";

    private string Title => _mode switch
    {
        "light" => "Theme: light (click for dark)",
        "dark" => "Theme: dark (click for system)",
        _ => "Theme: system (click for light)",
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var m = await JS.InvokeAsync<string>("hudTheme.get");
            if (!string.IsNullOrEmpty(m) && m != _mode) { _mode = m; StateHasChanged(); }
        }
        catch (JSException) { /* JS not ready — keep the default label */ }
        catch (InvalidOperationException) { /* prerender / no circuit */ }
    }

    private async Task Cycle()
    {
        _mode = await JS.InvokeAsync<string>("hudTheme.cycle");
    }
}
