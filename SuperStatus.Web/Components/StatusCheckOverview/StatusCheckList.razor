@using SuperStatus.Data.Entities
@using SuperStatus.Data.Repositories
@inject StatusApiClient StatusApi
@inject ConfigurationApiClient ConfigurationApiClient
@implements IAsyncDisposable

<MudGrid>
    <MudItem xs="0" sm="2" md="2">
    </MudItem>
    <MudItem xs="12" sm="8" md="8">
        <MudGrid>
            @if (statusCheckSet == null)
            {
                <MudItem xs="12">
                    <MudText Class="d-flex align-center justify-center">Loading Status...</MudText>
                </MudItem>

            }
            else
            {
                foreach (var statusCheck in statusCheckSet.Results)
                {
                    <MudItem xs="12">
                        <StatusCheckOverviewCard statusCheck="statusCheck" />
                    </MudItem>
                }
            }
        </MudGrid>
    </MudItem>
    <MudItem xs="0" sm="2" md="2">
    </MudItem>
</MudGrid>

@code {
    private IPagedResult<StatusCheckViewModel>? statusCheckSet;
    private PeriodicTimer? timer;
    private CancellationTokenSource cts = new CancellationTokenSource();

    protected override async Task OnInitializedAsync()
    {
        var config = await ConfigurationApiClient.GetConfigurationAsync();

        await LoadStatusChecksAsync();

        timer = new PeriodicTimer(TimeSpan.FromSeconds(config.StatusCheckViewRefreshIntervalInSeconds));

        _ = UpdateDataAsync();
    }

    private async Task UpdateDataAsync()
    {
        try
        {
            while (await timer!.WaitForNextTickAsync(cts.Token))
            {
                await LoadStatusChecksAsync();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
            // Handle cancellation if needed
        }
    }

    private async Task LoadStatusChecksAsync()
    {
        statusCheckSet = await StatusApi.GetStatusAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (timer is not null)
        {
            cts.Cancel();
            timer.Dispose();
            cts.Dispose();
        }
    }
}