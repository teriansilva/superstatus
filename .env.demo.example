# Public demo environment template — issue #377.
#
# Unlike .env.staging / .env.production, the real file (.env.demo) is NOT tracked
# and NOT materialised by a deploy workflow. The demo has no deploy workflow: it is
# rebuilt hourly by scripts/demo-reset.sh, which runs `git reset --hard origin/main`
# and would clobber a tracked env file every single hour. So the real values live in
# an untracked, gitignored /opt/superstatus-demo/.env.demo (mode 600) that survives
# the reset. Copy this template there once, fill it in, and never commit it.
#
#   cp .env.demo.example .env.demo && chmod 600 .env.demo && $EDITOR .env.demo
#
# The demo-mode flag is deliberately absent from this file. docker-compose.demo.yml
# hardcodes it, so the demo affordances cannot be switched off (or on) by editing an
# env file on a host. DemoComposeTests greps every other compose/env/install surface
# for the flag's name and fails if it appears at all — including in a comment — so that
# a plain `grep -r` audit stays trustworthy. Please don't name it here.

# Postgres. Regenerated data every hour, but the credential itself persists —
# still generate a real one: openssl rand -base64 24
POSTGRES_USER=superstatus
POSTGRES_PASSWORD=CHANGE_ME

# Public URLs (must match the reverse-proxy + DNS setup).
WEBAPP_HTTP=https://demo.status.superstatus.io
IDP_HTTP=https://id.demo.status.superstatus.io

# OIDC client secret shared between Identity (registers the OpenIddict
# `aspNetCoreAuth` application with this value) and Web (presents it on the
# OIDC code flow + client-credentials flow). Both must match.
# Generate with: openssl rand -base64 24
OIDC_WEB_CLIENT_SECRET=CHANGE_ME

# The demo administrator (admin@superstatus.io / admin) is seeded by Identity on every
# reset, because the demo compose enables demo mode. It is not configurable here — see
# SuperStatusIdentityDbInitializer.SeedDemoAdministrator.
