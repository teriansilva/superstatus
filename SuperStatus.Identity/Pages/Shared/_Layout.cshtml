@using SuperStatus.Identity.Services
@inject DemoModeInfo DemoMode
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SuperStatus</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SuperStatus.Identity.styles.css" asp-append-version="true" />
    @* Issue #151: tactical-HUD skin — loaded AFTER Bootstrap so the tokens win.
       hud-theme.css is shared with SuperStatus.Web for palette parity. *@
    <link rel="stylesheet" href="~/css/hud-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/hud-identity.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="hud-auth">
    @* has-demo-chip lets the mobile stylesheet reclaim the topbar space the countdown
       chip needs, without touching a non-demo instance's chrome. *@
    <header class="hud-auth-topbar @(DemoMode.IsEnabled ? "has-demo-chip" : null)">
        <a class="brand" asp-area="" asp-page="/Index">
            <span class="logo" aria-hidden="true"></span>
            <span class="name">SUPER<em>STATUS</em></span>
        </a>
        <span class="tag accent"><span class="led up"></span>Secure<span class="sep">//</span>Access</span>
        @* #377: demo countdown chip. The reset instant is computed server-side from
           DemoMode.NextResetUtc and stamped here; demo-countdown.js only formats the
           difference, so the browser never reimplements the schedule.

           The attribute lives on this chip rather than on <body> because Razor renders
           a null plain-HTML attribute as `attr=""` (the omit-when-null behaviour is a
           tag-helper feature). Hanging it off an element that only exists in demo mode
           means a real deployment's markup carries no trace of it at all. *@
        @if (DemoMode.IsEnabled)
        {
            <span class="hud-demo-chip" data-demo-reset-at="@DemoMode.NextResetIso8601">
                <span class="dot" aria-hidden="true"></span>
                <span class="label-long">Public demo&nbsp;·&nbsp;</span>resets in
                <span class="hud-demo-countdown" data-demo-countdown>--:--</span>
            </span>
        }
    </header>

    <main role="main" class="hud-auth-main">
        @RenderBody()
    </main>

    <footer class="hud-auth-footer">
        Unclassified // Internal use &nbsp;·&nbsp; SuperStatus identity &nbsp;·&nbsp; <a asp-area="" asp-page="/Privacy">Privacy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (DemoMode.IsEnabled)
    {
        <script src="~/js/demo-countdown.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>