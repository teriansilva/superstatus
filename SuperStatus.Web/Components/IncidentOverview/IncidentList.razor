@using Humanizer
@using SuperStatus.Configuration
@using SuperStatus.Data.Entities
@inject IncidentApiClient IncidentApi

<MudGrid>

    <MudItem xs="12" >
        <MudGrid>
            @if (incidentSetByDays == null)
            {
                <MudItem xs="12">
                    <MudText Class="d-flex align-center justify-center">Loading Incidents...</MudText>
                </MudItem>
            }
            else
            {
                foreach (var day in incidentSetByDays.Keys)
                {
                    if (incidentSetByDays[day].Count == 0)
                    {
                        <MudItem xs="12">
                            <MudText Class="d-flex align-center justify-center">@day.ToShortDateString()</MudText>
                        </MudItem>
                        <MudItem xs="12">
                            <MudText Class="d-flex align-center justify-center" Typo="Typo.caption">No incidents</MudText>
                        </MudItem>

                        continue;
                    }
                    <MudItem xs="12">
                        <MudText Typo="Typo.h6">@day.ToLongDateString()</MudText>
                    </MudItem>
                    @foreach (var incident in incidentSetByDays[day])
                    {
                        <MudItem xs="12">
                            <MudPaper Class="pa-3">
                                <MudText Typo="Typo.subtitle1">@incident.Title</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@incident.Description</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Occurred @incident.Created.Humanize()</MudText>

                            </MudPaper>
                        </MudItem>
                    }
                }
            }
            
        </MudGrid>
    </MudItem>

</MudGrid>

@code {


    private IDictionary<DateTime, List<IncidentViewModel>>? incidentSetByDays;
    private CancellationTokenSource cts = new CancellationTokenSource();

    protected override async Task OnInitializedAsync()
    {
        await LoadIncidentsAsync();
    }

    private async Task LoadIncidentsAsync()
    {
        incidentSetByDays = await IncidentApi.GetIncidentsAsync();
    }


}