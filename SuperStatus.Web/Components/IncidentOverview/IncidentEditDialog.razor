@using Humanizer
@using Microsoft.AspNetCore.Components.Authorization

@inject IncidentApiClient IncidentApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" @bind-IsValid="@_isValid">
            <MudGrid>
                <MudItem xs="12">
                    <MudText Typo="Typo.h6" Class="mb-4">Incident Information</MudText>
                    <MudPaper Class="pa-4">
                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField T="string"
                                              @bind-Value="Incident.Title"
                                              Label="Title"
                                              For="@(()=>Incident.Title)"
                                              Required="true"
                                              RequiredError="Title is required."
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12">
                                <MudTextField T="string"
                                              @bind-Value="Incident.Description"
                                              Label="Description"
                                              For="@(()=>Incident.Description)"
                                              Lines="5"
                                              Placeholder="Describe the incident"
                                              Variant="Variant.Outlined" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSwitch @bind-Value="Incident.Resolved" 
                                           Color="Color.Success" 
                                           Label="Resolved" />
                            </MudItem>
                            <MudItem xs="12" md="6">
                                <MudSwitch @bind-Value="Incident.VisibleToPublic" 
                                           Color="Color.Primary" 
                                           Label="Visible to Public" />
                            </MudItem>
                            @if (Incident.Id > 0)
                            {
                                <MudItem xs="12" md="6">
                                    <MudTextField T="string"
                                                  Value="@Incident.Created.ToString("g")"
                                                  Label="Created"
                                                  ReadOnly="true"
                                                  Variant="Variant.Outlined" /> 
                                </MudItem>
                                <MudItem xs="12" md="6">
                                    <MudTextField T="string"
                                                  Value="@(Incident.AutomaticallyGeneratedReport ? "Yes" : "No")"
                                                  Label="Auto-Generated"
                                                  ReadOnly="true"
                                                  Variant="Variant.Outlined" />
                                </MudItem>
                            }
                        </MudGrid>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" 
                   Variant="Variant.Outlined" 
                   Color="Color.Secondary"
                   Disabled="@_submitting">
            Cancel
        </MudButton>
        <MudButton OnClick="SubmitAsync" 
                   Disabled="@(!_isValid || _submitting)" 
                   Color="Color.Primary" 
                   Variant="Variant.Filled">
            @if (_submitting)
            {
                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                <MudText Class="ms-2">Saving...</MudText>
            }
            else
            {
                <MudText>Save</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public required IncidentViewModel Incident { get; set; }

    private MudForm? _form;
    private bool _isValid;
    private bool _submitting;

    private async Task SubmitAsync()
    {
        if (_form is null) return;
        
        await _form.Validate();
        if (!_isValid) return;

        _submitting = true;
        try
        {
            await IncidentApi.UpdateOrAddIncident(Incident);
            Snackbar.Add("Incident saved successfully!", Severity.Success);
            MudDialog.Close(DialogResult.Ok(Incident));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving incident: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}