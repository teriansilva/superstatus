@*
    Admin — tactical operator console (issue #95 Phase 4; editing dashboard #159;
    tabbed restructure #266).

    A calm HUD operations surface and the single place to manage state, organized
    into in-page tabs:
      - Overview   — instance-telemetry strip fed by /statuscheck/summary (#104).
      - Checks     — StatusCheckAdminList: add / edit / run-now / pause-resume (#159).
      - SLAs       — SLA definitions panel (#293 Phase C; promoted to its own tab
                     in #302) — SLAs govern how checks classify their days.
      - Incidents  — IncidentList in Manage mode: report / edit incidents (#159).
      - Alerts     — alert profiles/log (#291/#253) plus a pointer to provider
                     settings now owned by Plugins (#367). #343 Phase 4: webhooks are folded into the
                     notification-channel model (a `webhook` channel on an alert
                     profile), so their deliveries appear in the unified alert log
                     here — there is no longer a standalone Webhooks tab.
      - Settings   — site branding/footer + AI/automation (#167/#168) + updates (#249).

    Panels stay mounted and toggle via [hidden], so switching tabs never drops a
    half-typed edit. The public status page (/) is read-only; all editing lives
    here, behind [Authorize].
*@
@page "/admin"
@using SuperStatus.Configuration
@using SuperStatus.Data.ViewModels
@using SuperStatus.Web.Components.Admin
@using SuperStatus.Web.Components.Hud
@using SuperStatus.Web.Components.StatusCheckOverview
@attribute [Authorize]
@inject StatusApiClient StatusApi
@inject SettingsApiClient SettingsApi
@inject IssuerModeInfo IssuerMode
@inject IJSRuntime JS

<PageTitle>SuperStatus — Operator Console</PageTitle>

@if (!_loaded)
{
    <div class="admin-console">
        <HudCallsign Label="CONSOLE" Value="Loading…" />
    </div>
}
else if (!_onboarded)
{
    @* #181 Phase 3: first-run wizard renders inline until setup is finished. *@
    <SetupWizard />
}
else
{
<div class="admin-console">
    @* #358: unpinned-issuer security reminder. Shows only in the self-host dynamic
       mode while no allowed sign-in host is pinned (relaxed) — clears itself once the
       operator sets the allowlist (Settings → Access & security). Amber nudge, not a
       red alarm: relaxed is a valid first-run state. *@
    @if (IssuerMode.IsDynamic && !_authHostsConfigured)
    {
        <div class="issuer-banner" role="alert">
            <span class="issuer-banner-glyph" aria-hidden="true">⚠</span>
            <div class="issuer-banner-body">
                <span class="issuer-banner-title">Sign-in issuer is unpinned</span>
                <span class="issuer-banner-text">
                    SuperStatus is accepting the login server on whatever address this host is
                    reached at. Fine for first setup — but pin your public address so a spoofed
                    host can't drive the login flow.
                </span>
            </div>
            <button class="btn issuer-banner-action" type="button" @onclick="GoToAuthHosts">Set allowed hosts →</button>
        </div>
    }

    @* Console header + tab bar. The callsign hugs the tab strip; the
       .admin-console gap keeps a uniform 32px between the panes below. *@
    <div class="admin-section">
        <HudCallsign Label="CONSOLE" Value="Operator console" Meta="@_metaLine" />
        <nav class="console-tabs" role="tablist" aria-label="Console sections">
            @foreach (var t in Tabs)
            {
                <button type="button"
                        role="tab"
                        class="console-tab @(_tab == t.Key ? "active" : "")"
                        aria-selected="@(_tab == t.Key ? "true" : "false")"
                        @onclick="@(() => _tab = t.Key)">
                    @t.Label
                </button>
            }
        </nav>
    </div>

    @* ── Overview ─────────────────────────────────────────────── *@
    <div class="tab-pane" data-pane="overview" hidden="@(_tab != Tab.Overview)">
        @if (_showWelcome)
        {
            @* #181: one-time post-onboarding welcome card; dismissal is per-browser. *@
            <HudPanel Accent="primary" ExtraClass="admin-frame welcome-card">
                <HudCallsign Label="WELCOME" Value="Your status page is live" Meta="first-run" />
                <p class="admin-note">
                    This is the operator console — the one place to manage everything.
                    Use the tabs above to add or edit <strong>checks</strong>, report
                    <strong>incidents</strong>, configure <strong>alerts</strong>
                    (email &amp; browser push), and tune <strong>settings</strong>
                    (branding, AI, updates). The public status page stays read-only.
                </p>
                <div style="display:flex;justify-content:flex-end;margin-top:16px">
                    <button class="btn primary" type="button" @onclick="DismissWelcome">Got it</button>
                </div>
            </HudPanel>
        }

        <HudPanel Accent="primary" ExtraClass="admin-frame">
            @if (_summary is null)
            {
                <HudCallsign Label="INSTANCE" Value="Telemetry unavailable" />
                <p class="admin-note">Summary telemetry is not reachable right now.</p>
            }
            else
            {
                <HudCallsign Label="INSTANCE" Value="Operator overview" Meta="@_metaLine" />
                <HudTelemetryStrip>
                    <HudChip K="Services" V="@_summary.Services.Total.ToString()" />
                    <HudChip K="Up" V="@_summary.Services.Up.ToString()" Tone="accent" />
                    <HudChip K="Degraded" V="@_summary.Services.Degraded.ToString()" Tone="@(_summary.Services.Degraded > 0 ? "degraded" : "")" />
                    <HudChip K="Down" V="@_summary.Services.Down.ToString()" Tone="@(_summary.Services.Down > 0 ? "critical" : "")" />
                    <HudChip K="Uptime 30d" V="@UptimeLabel" Tone="accent" />
                    <HudChip K="Incidents 30d" V="@_summary.Incidents30d.ToString()" />
                    @* #82: this global value is now the scheduler *tick*, not the
                       per-check cadence — per-check intervals live on each check. *@
                    <HudChip K="Scheduler tick" V="@($"{SuperStatusConfig.JobIntervallInSeconds}s")" />
                </HudTelemetryStrip>
            }
        </HudPanel>
    </div>

    @* ── Checks ───────────────────────────────────────────────── *@
    <div class="tab-pane" data-pane="checks" hidden="@(_tab != Tab.Checks)">
        @* #159 Phase 2: the console is the editing surface; the public page (/) is read-only. *@
        <StatusCheckAdminList />
    </div>

    @* ── SLAs ─────────────────────────────────────────────────── *@
    @* #302: SLAs are their own management surface (own entities + edit dialog),
       promoted from under the Checks list to a first-class tab. *@
    <div class="tab-pane" data-pane="slas" hidden="@(_tab != Tab.Slas)">
        <SlaListPanel />
    </div>

    @* ── Incidents ────────────────────────────────────────────── *@
    <div class="tab-pane" data-pane="incidents" hidden="@(_tab != Tab.Incidents)">
        <SuperStatus.Web.Components.IncidentOverview.IncidentList Manage="true" />
    </div>

    @* ── Webhooks (folded out) ─────────────────────────────────── *@
    @* #343 Phase 4: webhooks are folded into the notification-channel model, so this
       tab is removed from the nav (see the Tabs list). The pane markup is retained
       (unreachable) to avoid churn; the standalone panels + the schema-driven
       per-channel config on alert profiles are reconciled in Phase 5. *@
    <div class="tab-pane" data-pane="webhooks" hidden="@(_tab != Tab.Webhooks)">
        <WebhookListPanel />
        <WebhookLogPanel />
    </div>

    @* ── Alerts ───────────────────────────────────────────────── *@
    @* Alert-notification scope: reusable alert profiles (#291 Phase C) above
       the audit trail (alert log #253). Provider settings live on Plugins.
       #343 Phase 4: webhooks are folded into alert-profile channels, so webhook
       deliveries also land in the unified alert log here. *@
    <div class="tab-pane" data-pane="alerts" hidden="@(_tab != Tab.Alerts)">
        <AlertProfileListPanel />
        <AlertLogPanel />
    </div>

    @* ── Settings ─────────────────────────────────────────────── *@
    <div class="tab-pane" data-pane="settings" hidden="@(_tab != Tab.Settings)">
        <SiteSettingsPanel />
        <UpdatesPanel />
    </div>

    @* ── About ────────────────────────────────────────────────── *@
    @* #319: support the project (Buy-me-a-coffee) + app/version/attribution,
       mirroring the Agent-Sessions settings About page. *@
    <div class="tab-pane" data-pane="about" hidden="@(_tab != Tab.About)">
        <AboutPanel />
    </div>
</div>
}

@code {
    private enum Tab { Overview, Checks, Slas, Incidents, Webhooks, Alerts, Settings, About }

    private static readonly (Tab Key, string Label)[] Tabs =
    {
        (Tab.Overview, "Overview"),
        (Tab.Checks, "Checks"),
        (Tab.Slas, "SLAs"),
        (Tab.Incidents, "Incidents"),
        // #343 Phase 4: the standalone Webhooks tab is hidden — webhooks are folded into
        // the notification-channel model (managed as a `webhook` channel on an alert
        // profile). The schema-driven per-channel config form (incl. webhook URL) lands
        // with Phase 5; the pane/enum are retained so no references break.
        (Tab.Alerts, "Alerts"),
        (Tab.Settings, "Settings"),
        (Tab.About, "About"),
    };

    private Tab _tab = Tab.Overview;
    private DashboardSummaryViewModel? _summary;
    private string _metaLine = "";
    private bool _loaded;
    private bool _onboarded;
    private bool _showWelcome;
    private bool _authHostsConfigured;

    protected override async Task OnInitializedAsync()
    {
        // #181: decide wizard-vs-console up front so onboarded installs never
        // flash the wizard. Only load console telemetry once onboarded.
        var settings = await SettingsApi.GetSettingsAsync();
        _onboarded = settings.OnboardedUtc.HasValue;
        // #358: drives the unpinned-issuer banner (dynamic mode + empty allowlist).
        _authHostsConfigured = settings.AllowedAuthHosts.Count > 0;
        if (_onboarded)
        {
            _summary = await StatusApi.GetDashboardSummaryAsync();
            _metaLine = $"UTC {DateTime.UtcNow:HH:mm:ss}";
        }
        _loaded = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || !_onboarded) return;
        try
        {
            // One-time welcome card until the operator dismisses it (per-browser).
            var dismissed = await JS.InvokeAsync<string?>("localStorage.getItem", "hudWelcomeDismissed");
            if (dismissed != "1") { _showWelcome = true; StateHasChanged(); }
        }
        catch (JSException) { /* JS not ready — skip the card */ }
        catch (InvalidOperationException) { /* prerender / no circuit */ }
    }

    private async Task DismissWelcome()
    {
        _showWelcome = false;
        try { await JS.InvokeVoidAsync("localStorage.setItem", "hudWelcomeDismissed", "1"); }
        catch (JSException) { }
        catch (InvalidOperationException) { }
    }

    private string UptimeLabel => _summary is null ? "—" : $"{_summary.Uptime30dPct:0.00}%";

    // #358: jump to Settings (where the Access & security allowlist editor lives).
    private void GoToAuthHosts() => _tab = Tab.Settings;
}
