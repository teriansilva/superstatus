@*
    SiteSettingsPanel — issue #167 Phase 2 + #170 footer.

    Operator editor for the site settings singleton — branding (title / logo /
    accent) and the footer (text / links / Admin-link toggle) — over the /settings
    API. Lives on the [Authorize] admin console. A successful save forces a full
    reload so the SiteSettingsProvider re-reads everything and the recolor / title
    / logo / footer apply immediately. The API is the validation authority (accent
    → #rrggbb or default, logo + link URLs → http(s) or dropped); this panel only
    mirrors that intent in the UI.
*@
@using SuperStatus.Data.ViewModels
@using SuperStatus.Web.Components.Hud
@inject SettingsApiClient SettingsApi
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<HudPanel Accent="primary" ExtraClass="settings-frame">
    <HudCallsign Label="SETTINGS" Value="Site branding & footer" Meta="title · logo · accent · footer" />

    @if (_model is null)
    {
        <p class="admin-note">Loading branding settings…</p>
    }
    else
    {
        <div class="settings-grid">
            <label class="settings-field">
                <span class="settings-label">Site title</span>
                <input class="settings-input" type="text" maxlength="120" @bind="_model.Title"
                       placeholder="e.g. Acme Service Status" />
                <span class="settings-hint">Shown as the wordmark in the top bar. Blank keeps the default SUPER//STATUS mark.</span>
            </label>

            <label class="settings-field">
                <span class="settings-label">Subtitle</span>
                <input class="settings-input" type="text" maxlength="160" @bind="_model.Subtitle"
                       placeholder="e.g. Acme Service Status Information" />
                <span class="settings-hint">The line beside the wordmark. Blank falls back to the configured description.</span>
            </label>

            <label class="settings-field">
                <span class="settings-label">Logo URL</span>
                <input class="settings-input" type="url" @bind="_model.LogoUrl"
                       placeholder="https://cdn.example.com/logo.svg" />
                <span class="settings-hint">Optional. Must be an http(s) URL — other schemes are cleared on save.</span>
            </label>

            <div class="settings-field">
                <span class="settings-label">Accent colour</span>
                <div class="settings-accent">
                    <input class="settings-swatch" type="color" aria-label="Accent colour picker"
                           @bind="_model.AccentColor" />
                    <input class="settings-input settings-hex" type="text" maxlength="7"
                           aria-label="Accent hex value" @bind="_model.AccentColor" />
                    <span class="settings-accent-preview" style="@PreviewStyle">PREVIEW</span>
                </div>
                <span class="settings-hint">#rrggbb. Recolours the HUD chrome only — status colours (up / degraded / down) never change.</span>
            </div>
        </div>

        @* #170: footer customization. *@
        <div class="settings-section">
            <span class="settings-label">Footer text</span>
            <input class="settings-input" type="text" maxlength="200" @bind="_model.FooterText"
                   placeholder="e.g. UNCLASSIFIED // INTERNAL USE" />
            <span class="settings-hint">The static footer line — replaces the old rotating classification.</span>

            <span class="settings-label settings-sublabel">Footer links</span>
            @foreach (var link in _model.FooterLinks)
            {
                <div class="settings-linkrow">
                    <input class="settings-input" type="text" maxlength="60" placeholder="Label" @bind="link.Label" />
                    <input class="settings-input" type="url" placeholder="https://…" @bind="link.Url" />
                    <button class="btn" type="button" @onclick="@(() => RemoveLink(link))" aria-label="Remove link">✕</button>
                </div>
            }
            <div class="settings-linkactions">
                <button class="btn" type="button" @onclick="AddLink" disabled="@(_model.FooterLinks.Count >= 8)">+ Add link</button>
            </div>
            <span class="settings-hint">Up to 8. Each needs a label + an http(s) URL; invalid links are dropped on save. Links open in a new tab (rel="noopener").</span>

            <label class="settings-check">
                <input type="checkbox" @bind="_model.ShowAdminLink" />
                <span>Show the Admin / Operator-console link in the footer</span>
            </label>
        </div>

        @* #168: AI / automation — drafts an incident automatically when a check
           opted in (per-check toggle in the edit dialog) stays down past the
           threshold. Off by default; degrades to a templated incident if the
           model is unreachable. *@
        <div class="settings-section">
            <span class="settings-label">AI / Automation</span>
            <label class="settings-check">
                <input type="checkbox" @bind="_model.AiEnabled" />
                <span>Enable AI-authored incidents on sustained downtime</span>
            </label>
            <span class="settings-hint">Uses an OpenAI-compatible endpoint to draft an incident title/description when an opted-in check is down past the threshold. Requires a base URL + model below; the public status colours never change.</span>

            <div class="settings-grid settings-ai">
                <label class="settings-field">
                    <span class="settings-label">Inference base URL</span>
                    <input class="settings-input" type="url" @bind="_model.AiBaseUrl"
                           placeholder="https://gateway.example.com/v1" />
                    <span class="settings-hint">OpenAI-compatible root; <code>/chat/completions</code> is appended. http(s) only.</span>
                </label>

                <label class="settings-field">
                    <span class="settings-label">Model</span>
                    <input class="settings-input" type="text" maxlength="120" @bind="_model.AiModel"
                           placeholder="e.g. gpt-4o-mini" />
                    <span class="settings-hint">Model name passed to the endpoint.</span>
                </label>

                <label class="settings-field">
                    <span class="settings-label">API key</span>
                    <input class="settings-input" type="password" autocomplete="new-password" @bind="_model.AiApiKey"
                           placeholder="@KeyPlaceholder" />
                    <span class="settings-hint">@KeyHint</span>
                </label>

                <label class="settings-field">
                    <span class="settings-label">Timeout (seconds)</span>
                    <input class="settings-input" type="number" min="5" max="120" @bind="_model.AiTimeoutSeconds" />
                    <span class="settings-hint">Per-request inference timeout (5–120). A slow model never stalls checks.</span>
                </label>

                <label class="settings-field">
                    <span class="settings-label">Downtime threshold (minutes)</span>
                    <input class="settings-input" type="number" min="1" max="1440" @bind="_model.AutoIncidentThresholdMinutes" />
                    <span class="settings-hint">How long a check must stay down before an incident is drafted (1–1440). Default per check; the check must also opt in.</span>
                </label>
            </div>

            <label class="settings-field settings-promptfield">
                <span class="settings-label">Prompt</span>
                <textarea class="settings-input settings-prompt" rows="7" maxlength="4000" @bind="_model.AiPromptTemplate"></textarea>
                <span class="settings-hint">The exact instruction sent to the model. Placeholders <code>{service}</code> <code>{url}</code> <code>{downSince}</code> <code>{minutes}</code> <code>{symptom}</code> are filled per incident. Leave as-is (or clear) to use the built-in default; the model is always constrained to return JSON.</span>
            </label>
        </div>

        @* #241 Phase B: SMTP / email alerts. Saved on its own endpoint so it can't be
           wiped by a branding save; the password is write-only. Per-check email alerts
           (toggle on a status check) send through this relay. *@
        <div class="settings-section">
            <span class="settings-label">Email alerts (SMTP)</span>
            <span class="settings-hint">Per-check email alerts send through this relay. Save, then send a test to verify.@(_model.SmtpVerifiedUtc is { } v ? $" Last verified {v:u}." : "")</span>

            <div class="settings-grid settings-ai">
                <label class="settings-field">
                    <span class="settings-label">SMTP host</span>
                    <input class="settings-input" type="text" maxlength="255" @bind="_model.SmtpHost" placeholder="smtp.example.com" />
                </label>
                <label class="settings-field">
                    <span class="settings-label">Port</span>
                    <input class="settings-input" type="number" min="1" max="65535" @bind="_model.SmtpPort" />
                    <span class="settings-hint">587 STARTTLS · 465 implicit TLS · 25 plain.</span>
                </label>
                <label class="settings-field">
                    <span class="settings-label">From address</span>
                    <input class="settings-input" type="email" @bind="_model.SmtpFromAddress" placeholder="alerts@example.com" />
                </label>
                <label class="settings-field">
                    <span class="settings-label">From name</span>
                    <input class="settings-input" type="text" maxlength="120" @bind="_model.SmtpFromName" placeholder="Acme Status" />
                </label>
                <label class="settings-field">
                    <span class="settings-label">Username</span>
                    <input class="settings-input" type="text" autocomplete="username" @bind="_model.SmtpUsername" placeholder="optional (blank = no auth)" />
                </label>
                <label class="settings-field">
                    <span class="settings-label">Password</span>
                    <input class="settings-input" type="password" autocomplete="new-password" @bind="_model.SmtpPassword" placeholder="@SmtpPasswordPlaceholder" />
                    <span class="settings-hint">@SmtpPasswordHint</span>
                </label>
                <label class="settings-field">
                    <span class="settings-label">Default recipients</span>
                    <input class="settings-input" type="text" @bind="_model.AlertDefaultRecipients" placeholder="ops@example.com, oncall@example.com" />
                    <span class="settings-hint">Used by checks with email alerts on but no per-check recipients. Comma/space-separated.</span>
                </label>
            </div>

            <label class="settings-check">
                <input type="checkbox" @bind="_model.SmtpUseStartTls" />
                <span>Use STARTTLS (recommended on port 587)</span>
            </label>

            <div class="settings-actions">
                <button class="btn primary" type="button" @onclick="SaveSmtp" disabled="@_savingSmtp">
                    @(_savingSmtp ? "Saving…" : "Save email settings")
                </button>
                <button class="btn" type="button" @onclick="SendTest" disabled="@_testing">
                    @(_testing ? "Sending…" : "Send test email")
                </button>
            </div>
            <span class="settings-hint">"Send test" uses the <em>saved</em> config + default recipients — save first, then test.</span>
        </div>

        @* #241 Phase C: per-device browser push opt-in (self-contained). *@
        <EnablePushButton />

        <div class="settings-actions">
            <button class="btn primary" type="button" @onclick="Save" disabled="@_saving">
                @(_saving ? "Saving…" : "Save settings")
            </button>
        </div>
    }
</HudPanel>

@code {
    private SiteSettingsViewModel? _model;
    private bool _saving;
    private bool _savingSmtp;
    private bool _testing;

    // #241 Phase B: the SMTP password is write-only — same masked pattern as the AI key.
    private string SmtpPasswordPlaceholder => _model?.SmtpPasswordSet == true ? "•••••••• (stored)" : "optional (blank = no auth)";
    private string SmtpPasswordHint => _model?.SmtpPasswordSet == true
        ? "A password is stored. Leave blank to keep it, or type a new value to replace it."
        : "Stored for the relay; cleared if you change the host/port/user/from. Never shown back.";

    private string PreviewStyle =>
        $"color:{_model?.AccentColor};border-color:{_model?.AccentColor};";

    // #168: the API key is write-only — never pre-filled. The placeholder/hint
    // reflect whether one is already stored so the operator can leave it blank
    // to keep the existing key, or type to replace it.
    private string KeyPlaceholder => _model?.AiApiKeySet == true ? "•••••••• (stored)" : "optional — depends on the gateway";
    private string KeyHint => _model?.AiApiKeySet == true
        ? "A key is stored. Leave blank to keep it, or type a new value to replace it."
        : "Sent as a Bearer token. Leave blank if the gateway needs no key. Never shown back after saving.";

    protected override async Task OnInitializedAsync()
    {
        var current = await SettingsApi.GetSettingsAsync();
        _model = new SiteSettingsViewModel
        {
            Title = current.Title,
            Subtitle = current.Subtitle,
            LogoUrl = current.LogoUrl,
            AccentColor = string.IsNullOrWhiteSpace(current.AccentColor) ? "#3fbf6f" : current.AccentColor,
            FooterText = current.FooterText,
            // Clone so edits/removes don't mutate the fetched instance.
            FooterLinks = current.FooterLinks.Select(l => new FooterLink { Label = l.Label, Url = l.Url }).ToList(),
            ShowAdminLink = current.ShowAdminLink,
            // #168: AI / automation. AiApiKey is never echoed by the API (always
            // null here); AiApiKeySet tells the UI whether one is stored so the
            // operator can leave the field blank to keep it.
            AiEnabled = current.AiEnabled,
            AiBaseUrl = current.AiBaseUrl,
            AiModel = current.AiModel,
            AiApiKey = null,
            AiApiKeySet = current.AiApiKeySet,
            AiTimeoutSeconds = current.AiTimeoutSeconds,
            AutoIncidentThresholdMinutes = current.AutoIncidentThresholdMinutes,
            // The API returns the effective prompt (default when unset) so the
            // operator sees + can edit exactly what the model is asked.
            AiPromptTemplate = current.AiPromptTemplate,
            // #241 Phase B: SMTP. Password is write-only (null on GET); the *Set flag
            // drives the masked placeholder.
            SmtpHost = current.SmtpHost,
            SmtpPort = current.SmtpPort,
            SmtpUseStartTls = current.SmtpUseStartTls,
            SmtpUsername = current.SmtpUsername,
            SmtpPassword = null,
            SmtpPasswordSet = current.SmtpPasswordSet,
            SmtpFromAddress = current.SmtpFromAddress,
            SmtpFromName = current.SmtpFromName,
            AlertDefaultRecipients = current.AlertDefaultRecipients,
            SmtpVerifiedUtc = current.SmtpVerifiedUtc,
        };
    }

    private void AddLink()
    {
        if (_model is null || _model.FooterLinks.Count >= 8) return;
        _model.FooterLinks.Add(new FooterLink());
    }

    private void RemoveLink(FooterLink link) => _model?.FooterLinks.Remove(link);

    private async Task Save()
    {
        if (_model is null || _saving) return;
        _saving = true;
        try
        {
            await SettingsApi.SaveSettingsAsync(_model);
            Snackbar.Add("Site settings saved — applying…", Severity.Success);
            // Full reload so SiteSettingsProvider re-reads + re-applies the accent.
            Nav.NavigateTo("/admin", forceLoad: true);
        }
        catch (Exception ex)
        {
            _saving = false;
            Snackbar.Add($"Could not save settings: {ex.Message}", Severity.Error);
        }
    }

    // #241 Phase B: SMTP saves to its own endpoint (no full reload — nothing to
    // re-theme). On success re-mask the password + refresh the verified stamp.
    private async Task SaveSmtp()
    {
        if (_model is null || _savingSmtp) return;
        _savingSmtp = true;
        try
        {
            var saved = await SettingsApi.SaveSmtpSettingsAsync(_model);
            _model.SmtpPassword = null;
            _model.SmtpPasswordSet = saved.SmtpPasswordSet;
            _model.SmtpVerifiedUtc = saved.SmtpVerifiedUtc;
            Snackbar.Add("Email settings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not save email settings: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingSmtp = false;
        }
    }

    // Sends through the SAVED relay to the default recipients; on success the server
    // stamps SmtpVerifiedUtc (mirrored here for the hint).
    private async Task SendTest()
    {
        if (_testing) return;
        _testing = true;
        try
        {
            var (ok, message) = await SettingsApi.SendTestEmailAsync(null);
            if (ok)
            {
                Snackbar.Add($"Test email sent to {message}.", Severity.Success);
                if (_model is not null) _model.SmtpVerifiedUtc = DateTime.UtcNow;
            }
            else
            {
                Snackbar.Add($"Test failed: {message}", Severity.Error);
            }
        }
        finally
        {
            _testing = false;
        }
    }
}
