@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@using SuperStatus.Web.Components.StatusCheckOverview


<PageTitle>Home</PageTitle>

<MudGrid>
    <MudItem xs="12" Class="d-flex align-center justify-center mud-width-full">

    </MudItem>
    <MudItem xs="12" Class="d-flex align-center justify-center mud-width-full">
        <MudText Typo="Typo.h6">Status</MudText>
    </MudItem>
    <MudItem xs="12">
        <StatusCheckList />
    </MudItem>
    <MudItem xs="12">
        <MudGrid>
            <MudItem xs="0" sm="2" md="3">
            </MudItem>
            <MudItem xs="12" sm="8" md="6" Class="d-flex align-center justify-center mud-width-full">
                <AuthorizeView>
                    <Authorized>
                        <MudFab Color="Color.Transparent" DropShadow="false" StartIcon="@Icons.Material.Filled.Add" Size="Size.Large" />
                    </Authorized>
                </AuthorizeView>
            </MudItem>
            <MudItem xs="0" sm="2" md="3">
            </MudItem>
        </MudGrid>
    </MudItem>
    <MudItem xs="12" Class="d-flex align-center justify-center mud-width-full">
        <MudText Typo="Typo.h6">Incidents</MudText>
    </MudItem>
    <MudItem xs="12">
        <MudGrid>
            <MudItem xs="0" sm="2" md="3">
            </MudItem>
            <MudItem xs="12" sm="8" md="6" Class="d-flex align-center justify-center mud-width-full">
                <AuthorizeView>
                    <Authorized>
                        <MudFab Color="Color.Transparent" DropShadow="false" StartIcon="@Icons.Material.Filled.Add" Size="Size.Large" />
                    </Authorized>
                </AuthorizeView>
            </MudItem>
            <MudItem xs="0" sm="2" md="3">
            </MudItem>
        </MudGrid>
    </MudItem>
</MudGrid>

